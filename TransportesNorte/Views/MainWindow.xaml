<Window x:Class="TransportesNorte.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TransportesNorte.Converters"
        Title="Transportes del Norte — Tablero de Control"
        Width="1000" Height="640"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <conv:BoolToVisibilityConverter         x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter  x:Key="InvBoolToVis"/>
        <conv:StringToVisibilityConverter       x:Key="StrToVis"/>

        <!-- Estilo base para los botones principales -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"   Value="#1E3A5F"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="18,9"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A4F7A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#152C47"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para boton Auditar dentro del DataGrid -->
        <Style x:Key="BtnAuditar" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#0D9488"/>
            <Setter Property="Padding"    Value="12,5"/>
            <Setter Property="FontSize"   Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0F766E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo encabezado de columna del DataGrid -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#1E3A5F"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush"  Value="#2A4F7A"/>
        </Style>

        <!-- Filas alternadas del DataGrid -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F9FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Contenido -->
            <RowDefinition Height="36"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="#1E3A5F">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x1F69B;" FontSize="26" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Transportes del Norte"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Sistema de Control de Salidas y Pesaje — Tablero de Control"
                                   Foreground="#93C5FD" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== CONTENIDO ========== -->
        <Grid Grid.Row="1" Margin="24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                <RowDefinition Height="Auto"/>  <!-- Mensaje de error -->
                <RowDefinition Height="*"/>     <!-- DataGrid / Spinner -->
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="↻  Actualizar lista"
                        Command="{Binding CargarDespachosCommand}"
                        Style="{StaticResource BtnPrimary}"/>
                <Button Content="Auditar"
                        Command="{Binding AbrirAuditoriaCommand}"
                        Style="{StaticResource BtnAuditar}"
                        Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Panel de error (visible solo cuando hay mensaje) -->
            <Border Grid.Row="1"
                    Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                    CornerRadius="4" Padding="14,10" Margin="0,0,0,10"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StrToVis}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#B91C1C" FontSize="13" TextWrapping="Wrap"/>
            </Border>

            <!-- Spinner de carga -->
            <TextBlock Grid.Row="2"
                       Text="Cargando despachos..."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="15" Foreground="#6B7280"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

            <!-- DataGrid -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Despachos}"
                      SelectedItem="{Binding SelectedDespacho}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E5E7EB"
                      HeadersVisibility="Column"
                      RowHeight="40"
                      FontSize="13"
                      BorderThickness="1" BorderBrush="#D1D5DB"
                      Background="White"
                      CanUserResizeRows="False"
                      Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Folio"
                                        Binding="{Binding Folio_Despacho}"
                                        Width="130"/>
                    <DataGridTextColumn Header="Centro Operativo"
                                        Binding="{Binding Centro_Operativo}"
                                        Width="150"/>
                    <DataGridTextColumn Header="Placa"
                                        Binding="{Binding Placa_Tracto}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Conductor"
                                        Binding="{Binding Nombre_Conductor}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Tara (Ton)"
                                        Binding="{Binding Peso_Tara, StringFormat=N2}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Teórico ERP (Ton)"
                                        Binding="{Binding Peso_Teorico_ERP, StringFormat=N2}"
                                        Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Mensaje cuando la lista esta vacia -->
            <TextBlock Grid.Row="2"
                       Text="No hay despachos pendientes de pesaje."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="#9CA3AF"
                       Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Despachos.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- ========== FOOTER ========== -->
        <Border Grid.Row="2" Background="#E5E7EB" Padding="24,0">
            <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="#6B7280">
                <Run Text="Despachos pendientes: "/>
                <Run Text="{Binding Despachos.Count, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
        </Border>
    </Grid>
</Window>
